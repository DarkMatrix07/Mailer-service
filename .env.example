SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=lakkisettidivyeshbhanu12@gmail.com
SMTP_PASS=your-gmail-app-password

# Default "From" when the caller doesn't supply one
MAIL_FROM=HMD Architects <lakkisettidivyeshbhanu12@gmail.com>
